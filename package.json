{
  "name": "lib-qqwry",
  "version": "1.3.4",
  "description": "Using NodeJS analytical IP Library (qqwry.dat) module.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "qqwry": "./dist/qqwry.cjs",
    "lib-qqwry": "./dist/qqwry.cjs"
  },
  "files": [
    "dist",
    "bin",
    "data"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "prepublishOnly": "pnpm build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cnwhy/lib-qqwry.git"
  },
  "keywords": [
    "qqwry",
    "纯真IP库",
    "IP地址"
  ],
  "author": {
    "name": "cnwhy"
  },
  "license": "BSD",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "gbk.js": "^0.2.4",
    "ipip-ipdb": "^0.6.0",
    "progress": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}